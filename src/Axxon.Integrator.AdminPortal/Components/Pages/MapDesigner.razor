@page "/maps/new"
@page "/maps/{Name}"
@inject IEntityMapStore MapStore
@inject IReadOnlyDictionary<string, IConnector> Connectors
@inject MappingEngine Mapping
@inject NavigationManager Nav
@using System.Text.Json
@using Axxon.Integrator.Core.Stores

<PageTitle>@(_isNew ? "Nuevo mapa" : Name) — Axxon Integrator</PageTitle>

<h1>@(_isNew ? "Nuevo mapa" : $"Mapa: {Name}")</h1>

@if (_error is not null)
{
    <div class="banner error">@_error</div>
}
@if (_metadataWarning is not null)
{
    <div class="banner warning">@_metadataWarning</div>
}

<section class="card">
    <h2>Definición</h2>
    <div class="form-grid">
        <label>Nombre
            <input @bind="_name" disabled="@(!_isNew)" placeholder="customers-dataverse-to-finops" />
        </label>
        <label>Estado
            <select @bind="_status">
                <option value="Active">Activo</option>
                <option value="Paused">Pausado</option>
            </select>
        </label>
        <label>Sistema origen
            <select @bind="_sourceSystem" @bind:after="OnSourceSystemChangedAsync">
                @foreach (var s in Connectors.Keys)
                {
                    <option value="@s">@s</option>
                }
            </select>
        </label>
        <label>Entidad origen
            <input list="source-entities" @bind="_sourceEntity" @bind:after="OnEntityChangedAsync" placeholder="account" />
            <datalist id="source-entities">
                @foreach (var e in _sourceEntities)
                {
                    <option value="@e" />
                }
            </datalist>
        </label>
        <label>Sistema destino
            <select @bind="_targetSystem" @bind:after="OnTargetSystemChangedAsync">
                @foreach (var s in Connectors.Keys)
                {
                    <option value="@s">@s</option>
                }
            </select>
        </label>
        <label>Entidad destino
            <input list="target-entities" @bind="_targetEntity" @bind:after="OnEntityChangedAsync" placeholder="CustomersV3" />
            <datalist id="target-entities">
                @foreach (var e in _targetEntities)
                {
                    <option value="@e" />
                }
            </datalist>
        </label>
    </div>
    <div class="companies">
        <span class="field-label">Empresas / legal entities (ninguna marcada = todas)</span>
        @if (_companyOptions.Count > 0)
        {
            <div class="key-options">
                @foreach (var c in _companyOptions)
                {
                    var company = c;
                    <label class="key-option">
                        <input type="checkbox" checked="@_companies.Contains(company)"
                               @onchange="e => ToggleCompany(company, (bool)e.Value!)" />
                        @company
                    </label>
                }
            </div>
        }
        else
        {
            @* Sin conector que liste empresas: degrada a texto libre separado por coma *@
            <input @bind="_companiesFreeText" @bind:after="SyncCompaniesFromText" placeholder="usmf, dat" />
        }
    </div>
</section>

<section class="card">
    <h2>Campos</h2>
    <table class="grid fields">
        <thead>
            <tr>
                <th>Campo origen</th>
                <th>Campo destino</th>
                <th>Transformación</th>
                <th>Value map</th>
                <th>Default</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in _rows)
            {
                var r = row;
                <tr>
                    <td>
                        <input list="source-fields" @bind="r.Source" />
                    </td>
                    <td>
                        <input list="target-fields" @bind="r.Target" @bind:after="PruneIntegrationKey" />
                    </td>
                    <td>
                        <select @bind="r.Transform">
                            <option value="">(ninguna)</option>
                            @foreach (var t in Mapping.TransformNames)
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </td>
                    <td>
                        <button class="btn" @onclick="() => ToggleValueMapAsync(r)">
                            Diccionario (@r.ValueMap.Count)
                        </button>
                    </td>
                    <td>
                        <input @bind="r.Default" />
                    </td>
                    <td>
                        <button class="btn danger" @onclick="() => RemoveRow(r)">✕</button>
                    </td>
                </tr>
                @if (r.ValueMapExpanded)
                {
                    <tr class="value-map-row">
                        <td colspan="6">
                            <div class="value-map-editor">
                                <span class="field-label">
                                    Diccionario de traducción de valores (option sets / enums) para
                                    «@(r.Source.Length > 0 ? r.Source : "campo origen")» → «@(r.Target.Length > 0 ? r.Target : "campo destino")»
                                </span>
                                @foreach (var pair in r.ValueMap)
                                {
                                    var p = pair;
                                    <div class="pair">
                                        <input list="@($"vm-src-{r.Id}")" placeholder="valor origen (ej. 1)" @bind="p.Key" />
                                        <span class="arrow">→</span>
                                        <input list="@($"vm-tgt-{r.Id}")" placeholder="valor destino (ej. Retail)" @bind="p.Value" />
                                        <button class="btn danger" @onclick="() => r.ValueMap.Remove(p)">✕</button>
                                    </div>
                                }
                                <datalist id="@($"vm-src-{r.Id}")">
                                    @foreach (var o in r.SourceOptions)
                                    {
                                        <option value="@o.Key">@o.Value</option>
                                    }
                                </datalist>
                                <datalist id="@($"vm-tgt-{r.Id}")">
                                    @foreach (var o in r.TargetOptions)
                                    {
                                        <option value="@o.Key">@o.Value</option>
                                    }
                                </datalist>
                                <button class="btn" @onclick="() => r.ValueMap.Add(new())">+ Agregar traducción</button>
                                <p class="hint">
                                    Un valor entrante sin traducción usa el Default del campo; sin Default,
                                    el evento se marca como error permanente (dead-letter) en vez de escribir
                                    un valor inválido en el destino.
                                </p>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
    <datalist id="source-fields">
        @foreach (var f in _sourceFields)
        {
            <option value="@f" />
        }
    </datalist>
    <datalist id="target-fields">
        @foreach (var f in _targetFields)
        {
            <option value="@f" />
        }
    </datalist>
    <button class="btn" @onclick="AddRow">+ Agregar campo</button>
</section>

<section class="card">
    <h2>Integration key</h2>
    <p class="hint">
        Campos del destino (posiblemente compuesta, como en Dual Write) que identifican
        el registro para el primer match cuando todavía no existe vínculo en el xref.
    </p>
    @if (!MappedTargets.Any())
    {
        <p class="placeholder">Mapeá al menos un campo destino para poder elegir la clave.</p>
    }
    else
    {
        <div class="key-options">
            @foreach (var target in MappedTargets)
            {
                var field = target;
                <label class="key-option">
                    <input type="checkbox" checked="@_integrationKey.Contains(field)"
                           @onchange="e => ToggleKey(field, (bool)e.Value!)" />
                    @field
                </label>
            }
        </div>
    }
</section>

<section class="toolbar">
    <button class="btn primary" @onclick="SaveAsync">Guardar (v@(_isNew ? 1 : _version + 1))</button>
    <button class="btn" @onclick="TogglePreview">@(_jsonPreview is null ? "Ver JSON" : "Ocultar JSON")</button>
    <a class="btn" href="/maps">Cancelar</a>
</section>

@if (_jsonPreview is not null)
{
    <section class="card">
        <h2>Documento JSON</h2>
        <p class="hint">Así se persiste el mapa (archivo local en desarrollo, blob en 'entity-maps' en producción — mismo documento).</p>
        <pre class="json">@_jsonPreview</pre>
    </section>
}

@code {
    [Parameter] public string? Name { get; set; }

    private bool _isNew => Name is null;

    private string _name = "";
    private string _sourceSystem = "dataverse";
    private string _sourceEntity = "";
    private string _targetSystem = "finops";
    private string _targetEntity = "";
    private readonly HashSet<string> _companies = new(StringComparer.OrdinalIgnoreCase);
    private string _companiesFreeText = "";
    private IReadOnlyList<string> _companyOptions = [];
    private MapStatus _status = MapStatus.Active;
    private int _version = 1;
    private List<FieldRow> _rows = [new()];
    private readonly HashSet<string> _integrationKey = new(StringComparer.OrdinalIgnoreCase);

    private IReadOnlyList<string> _sourceEntities = [];
    private IReadOnlyList<string> _targetEntities = [];
    private IReadOnlyList<string> _sourceFields = [];
    private IReadOnlyList<string> _targetFields = [];
    private readonly Dictionary<string, IReadOnlyDictionary<string, string>> _optionCache = new(StringComparer.OrdinalIgnoreCase);
    private string? _metadataWarning;
    private string? _error;
    private string? _jsonPreview;

    private IEnumerable<string> MappedTargets =>
        _rows.Select(r => r.Target.Trim())
             .Where(t => t.Length > 0)
             .Distinct(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        if (_isNew)
        {
            await LoadEntitiesAsync();
            await LoadCompaniesAsync();
            await LoadMetadataAsync();
            return;
        }

        var map = await MapStore.GetAsync(Name!, CancellationToken.None);
        if (map is null)
        {
            _error = $"No existe el mapa '{Name}'.";
            return;
        }

        _name = map.Name;
        _sourceSystem = map.SourceSystem;
        _sourceEntity = map.SourceEntity;
        _targetSystem = map.TargetSystem;
        _targetEntity = map.TargetEntity;
        _companies.UnionWith(map.Companies);
        _companiesFreeText = string.Join(", ", map.Companies);
        _status = map.Status;
        _version = map.Version;
        _rows = [.. map.Fields.Select(FieldRow.From)];
        _integrationKey.UnionWith(map.IntegrationKey);

        await LoadEntitiesAsync();
        await LoadCompaniesAsync();
        await LoadMetadataAsync();
    }

    private async Task LoadCompaniesAsync()
    {
        var options = new SortedSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var connector in Connectors.Values)
        {
            try
            {
                options.UnionWith(await connector.ListCompaniesAsync(CancellationToken.None));
            }
            catch (NotImplementedException)
            {
                // sin listado: si ningún conector aporta, degrada a texto libre
            }
            catch (Exception ex)
            {
                _metadataWarning = $"No se pudieron listar las empresas: {ex.Message}";
            }
        }

        // Un mapa existente no pierde selecciones que no estén en el listado
        // (empresa borrada, ambiente distinto): se muestran como opciones marcadas.
        options.UnionWith(_companies);
        _companyOptions = [.. options];
    }

    private void ToggleCompany(string company, bool selected)
    {
        if (selected)
        {
            _companies.Add(company);
        }
        else
        {
            _companies.Remove(company);
        }
    }

    private void SyncCompaniesFromText()
    {
        _companies.Clear();
        _companies.UnionWith(_companiesFreeText.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));
    }

    private async Task OnSourceSystemChangedAsync()
    {
        _metadataWarning = null;
        _sourceEntities = await EntitiesOfAsync(_sourceSystem);
        await LoadMetadataAsync();
    }

    private async Task OnTargetSystemChangedAsync()
    {
        _metadataWarning = null;
        _targetEntities = await EntitiesOfAsync(_targetSystem);
        await LoadMetadataAsync();
    }

    private async Task LoadEntitiesAsync()
    {
        _sourceEntities = await EntitiesOfAsync(_sourceSystem);
        _targetEntities = await EntitiesOfAsync(_targetSystem);
    }

    private async Task OnEntityChangedAsync()
    {
        _metadataWarning = null;
        await LoadMetadataAsync();
    }

    /// <summary>No limpia el warning: eso lo hacen los handlers de usuario, para no pisar avisos de la carga de entidades.</summary>
    private async Task LoadMetadataAsync()
    {
        _sourceFields = await FieldsOfAsync(_sourceSystem, _sourceEntity);
        _targetFields = await FieldsOfAsync(_targetSystem, _targetEntity);
    }

    private async Task<IReadOnlyList<string>> EntitiesOfAsync(string system)
    {
        if (!Connectors.TryGetValue(system, out var connector))
        {
            return [];
        }

        try
        {
            return await connector.ListEntitiesAsync(CancellationToken.None);
        }
        catch (NotImplementedException)
        {
            // Sin listado de entidades el combo degrada a texto libre (el datalist
            // vacío no bloquea la entrada manual); el aviso lo pone FieldsOfAsync.
            return [];
        }
        catch (Exception ex)
        {
            _metadataWarning = $"No se pudieron listar las entidades de {system}: {ex.Message}";
            return [];
        }
    }

    private async Task<IReadOnlyList<string>> FieldsOfAsync(string system, string entity)
    {
        if (string.IsNullOrWhiteSpace(entity) || !Connectors.TryGetValue(system, out var connector))
        {
            return [];
        }

        try
        {
            var metadata = await connector.GetMetadataAsync(entity.Trim(), CancellationToken.None);
            return [.. metadata.Fields.Keys.OrderBy(f => f, StringComparer.OrdinalIgnoreCase)];
        }
        catch (NotImplementedException)
        {
            // El conector todavía no expone metadata: el diseñador degrada a entrada
            // manual de nombres de campo en lugar de bloquear al usuario.
            _metadataWarning = "La metadata de los conectores no está disponible aún; escribí los nombres de campo a mano.";
            return [];
        }
        catch (Exception ex)
        {
            _metadataWarning = $"No se pudo leer la metadata de {system}/{entity}: {ex.Message}";
            return [];
        }
    }

    private void AddRow() => _rows.Add(new FieldRow());

    private void RemoveRow(FieldRow row)
    {
        _rows.Remove(row);
        PruneIntegrationKey();
    }

    private async Task ToggleValueMapAsync(FieldRow row)
    {
        row.ValueMapExpanded = !row.ValueMapExpanded;
        if (!row.ValueMapExpanded)
        {
            return;
        }

        // Pre-pobla los datalists con los valores reales del option set / enum de
        // cada lado; sin metadata (campo no enumerado, credenciales faltantes) los
        // datalists quedan vacíos y la entrada sigue siendo texto libre.
        row.SourceOptions = await OptionsOfAsync(_sourceSystem, _sourceEntity, row.Source);
        row.TargetOptions = await OptionsOfAsync(_targetSystem, _targetEntity, row.Target);
    }

    private async Task<IReadOnlyDictionary<string, string>> OptionsOfAsync(string system, string entity, string field)
    {
        var empty = new Dictionary<string, string>();
        if (string.IsNullOrWhiteSpace(entity) || string.IsNullOrWhiteSpace(field) ||
            !Connectors.TryGetValue(system, out var connector))
        {
            return empty;
        }

        var cacheKey = $"{system}|{entity.Trim()}|{field.Trim()}";
        if (_optionCache.TryGetValue(cacheKey, out var cached))
        {
            return cached;
        }

        try
        {
            var options = await connector.GetOptionSetAsync(entity.Trim(), field.Trim(), CancellationToken.None);
            _optionCache[cacheKey] = options;
            return options;
        }
        catch (NotImplementedException)
        {
            return empty;
        }
        catch (Exception ex)
        {
            _metadataWarning = $"No se pudieron leer los valores de {system}/{entity}.{field}: {ex.Message}";
            return empty;
        }
    }

    private void ToggleKey(string field, bool selected)
    {
        if (selected)
        {
            _integrationKey.Add(field);
        }
        else
        {
            _integrationKey.Remove(field);
        }
    }

    /// <summary>La clave solo puede referenciar campos destino que sigan mapeados.</summary>
    private void PruneIntegrationKey() =>
        _integrationKey.IntersectWith(MappedTargets);

    private EntityMap BuildMap(int version) => new()
    {
        Name = _name.Trim(),
        SourceSystem = _sourceSystem.Trim(),
        SourceEntity = _sourceEntity.Trim(),
        TargetSystem = _targetSystem.Trim(),
        TargetEntity = _targetEntity.Trim(),
        Status = _status,
        Companies = [.. _companies.OrderBy(c => c, StringComparer.Ordinal)],
        Fields = [.. _rows.Where(r => r.IsComplete).Select(r => r.ToFieldMap())],
        IntegrationKey = [.. _integrationKey],
        Version = version,
    };

    private async Task SaveAsync()
    {
        _error = Validate();
        if (_error is not null)
        {
            return;
        }

        try
        {
            await MapStore.SaveAsync(BuildMap(_isNew ? 1 : _version + 1), CancellationToken.None);
            Nav.NavigateTo("/maps");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private string? Validate()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            return "El mapa necesita un nombre.";
        }
        if (string.IsNullOrWhiteSpace(_sourceEntity) || string.IsNullOrWhiteSpace(_targetEntity))
        {
            return "Definí la entidad de origen y la de destino.";
        }
        if (string.Equals(_sourceSystem, _targetSystem, StringComparison.OrdinalIgnoreCase))
        {
            return "El origen y el destino no pueden ser el mismo sistema.";
        }
        if (!_rows.Any(r => r.IsComplete))
        {
            return "Mapeá al menos un campo (origen y destino).";
        }
        if (_integrationKey.Count == 0)
        {
            return "Elegí al menos un campo destino como integration key.";
        }
        return null;
    }

    private void TogglePreview()
    {
        if (_jsonPreview is not null)
        {
            _jsonPreview = null;
            return;
        }

        try
        {
            // BuildMap valida (p. ej. claves duplicadas en un diccionario): el error
            // se muestra en el banner en vez de tumbar el circuito.
            _jsonPreview = JsonSerializer.Serialize(BuildMap(_isNew ? 1 : _version + 1), JsonFileEntityMapStore.SerializerOptions);
            _error = null;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    /// <summary>Copia editable de un FieldMap. Los defaults se editan como texto; tipado fino: fase 4.</summary>
    private sealed class FieldRow
    {
        /// <summary>Para los ids únicos de los datalists del editor de diccionario.</summary>
        public readonly string Id = Guid.NewGuid().ToString("N")[..8];

        public string Source = "";
        public string Target = "";
        public string Transform = "";
        public List<ValuePair> ValueMap = [];
        public bool ValueMapExpanded;
        public IReadOnlyDictionary<string, string> SourceOptions = new Dictionary<string, string>();
        public IReadOnlyDictionary<string, string> TargetOptions = new Dictionary<string, string>();
        public string Default = "";

        public bool IsComplete => Source.Trim().Length > 0 && Target.Trim().Length > 0;

        public static FieldRow From(FieldMap f) => new()
        {
            Source = f.Source,
            Target = f.Target,
            Transform = f.Transform ?? "",
            ValueMap = f.ValueMap is null
                ? []
                : [.. f.ValueMap.Select(kv => new ValuePair { Key = kv.Key, Value = kv.Value })],
            Default = f.DefaultValue?.ToString() ?? "",
        };

        public FieldMap ToFieldMap() => new()
        {
            Source = Source.Trim(),
            Target = Target.Trim(),
            Transform = string.IsNullOrWhiteSpace(Transform) ? null : Transform,
            ValueMap = BuildValueMap(),
            DefaultValue = string.IsNullOrWhiteSpace(Default) ? null : Default.Trim(),
        };

        private IReadOnlyDictionary<string, string>? BuildValueMap()
        {
            var pairs = ValueMap.Where(p => p.Key.Trim().Length > 0).ToList();
            if (pairs.Count == 0)
            {
                return null;
            }

            var dictionary = new Dictionary<string, string>();
            foreach (var pair in pairs)
            {
                if (!dictionary.TryAdd(pair.Key.Trim(), pair.Value.Trim()))
                {
                    throw new InvalidOperationException(
                        $"El diccionario de '{Source}' tiene la clave duplicada '{pair.Key.Trim()}'.");
                }
            }
            return dictionary;
        }

        public sealed class ValuePair
        {
            public string Key = "";
            public string Value = "";
        }
    }
}

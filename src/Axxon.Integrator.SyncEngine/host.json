{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  },
  "extensions": {
    "serviceBus": {
      "sessionHandlerOptions": {
        "maxConcurrentSessions": 8
      },
      "maxAutoLockRenewalDuration": "00:05:00"
    }
  }
}
